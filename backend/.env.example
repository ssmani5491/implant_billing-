PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

JWT_SECRET=
JWT_EXPIRES_IN=8h

# App DB (MySQL) — items, invoices, users
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# HIS DB (Oracle) — patient lookup, READ ONLY. Connect string is host:port/service
HIS_ORACLE_HOST=
HIS_ORACLE_PORT=1521
HIS_ORACLE_SERVICE=
HIS_ORACLE_USER=
HIS_ORACLE_PASSWORD=

# HIS patient lookup query is hardcoded in backend/routes/patients.js against the
# confirmed real schema (IPADMISS/DOCTOR/DEPARTMENT/BED/NURSTATION join, filtered
# by PT_NO). No env-configurable table/column mapping needed anymore.

# NAS storage for vendor document PDFs/images. NAS_SHARE_PATH must be a Linux
# path this server can write to — either the CIFS share mounted directly on the
# Docker host and bind-mounted into the container (e.g. -v /mnt/vendor-documents:/mnt/vendor-documents),
# or a path mounted inside the container itself at runtime. Authentication to
# the SMB/CIFS share (username/password) happens at mount time, outside the app.
NAS_SHARE_PATH=/mnt/vendor-documents
